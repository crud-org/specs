---
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

const dbPath = path.join(process.cwd(), 'src/crud.db');
const db = new DatabaseSync(dbPath);

const sectionRows = db.prepare('SELECT id, name, description FROM crud_sections').all() as {
  id: string;
  name: string;
  description: string | null;
}[];

const ruleRows = db.prepare(
  'SELECT code, requirement, rule, section_codes FROM crud_api_rules WHERE code IS NOT NULL'
).all() as { code: string; requirement: string; rule: string; section_codes: string }[];

const termRows = db.prepare('SELECT id, label, definition FROM crud_terms').all() as {
  id: string;
  label: string;
  definition: string;
}[];

db.close();

type Rule = { code: string; requirement: string; rule: string };
type Section = { name?: string; description?: string; rules: Rule[] };
const sections: Record<string, Section> = {};

for (const s of sectionRows) {
  sections[s.id] = { name: s.name, description: s.description ?? undefined, rules: [] };
}
for (const r of ruleRows) {
  const codes: string[] = JSON.parse(r.section_codes);
  for (const code of codes) {
    if (!sections[code]) sections[code] = { rules: [] };
    sections[code].rules.push({ code: r.code, requirement: r.requirement, rule: r.rule });
  }
}

const reqOrder: Record<string, number> = { MUST: 1, SHOULD: 2, MAY: 3 };
for (const sec of Object.values(sections)) {
  sec.rules.sort(
    (a, b) => (reqOrder[a.requirement] ?? 4) - (reqOrder[b.requirement] ?? 4) || a.code.localeCompare(b.code)
  );
}

const terms: Record<string, { label: string; definition: string }> = {};
for (const t of termRows) {
  terms[t.id] = { label: t.label, definition: t.definition };
}
---

<style is:global>
  /* Badge color tokens — change with Starlight's theme */
  :root {
    --sl-pop-must-bg:    #fee2e2; --sl-pop-must-fg:    #b91c1c;
    --sl-pop-should-bg:  #fef9c3; --sl-pop-should-fg:  #854d0e;
    --sl-pop-may-bg:     #dbeafe; --sl-pop-may-fg:     #1d4ed8;
  }
  :root[data-theme='dark'] {
    --sl-pop-must-bg:    rgba(127, 29, 29, 0.4);  --sl-pop-must-fg:    #fca5a5;
    --sl-pop-should-bg:  rgba(113, 63, 18, 0.4);  --sl-pop-should-fg:  #fcd34d;
    --sl-pop-may-bg:     rgba(30,  58, 138, 0.4); --sl-pop-may-fg:     #93c5fd;
  }

  #sl-section-popover {
    position: fixed;
    z-index: 9999;
    width: 420px;
    max-height: 520px;
    overflow-y: auto;
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 12px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.12s ease;
    font-family: var(--sl-font);
    font-size: 1rem; /* reset — prevents inheritance from host element */
  }
  #sl-section-popover.visible {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script define:vars={{ sections, terms }}>
  function ruleToHtml(text) {
    return text
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_, t, url) => {
        const ext = url.startsWith('http');
        return `<a href="${url}"${ext ? ' target="_blank" rel="noopener noreferrer"' : ''}>${t}</a>`;
      })
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\\\$/g, '$');
  }

  function hashToSectionCode(hash) {
    const m = hash.match(/^(\d+)/);
    return m ? `G${m[1]}` : null;
  }

  let hideTimer;

  function getPop() {
    let pop = document.getElementById('sl-section-popover');
    if (!pop) {
      pop = document.createElement('div');
      pop.id = 'sl-section-popover';
      pop.setAttribute('role', 'tooltip');
      document.body.appendChild(pop);
      pop.addEventListener('mouseenter', () => clearTimeout(hideTimer));
      pop.addEventListener('mouseleave', hide);
    }
    return pop;
  }

  const codeStyle = 'font-size:0.75rem;font-family:var(--sl-font-mono);font-weight:600;color:var(--sl-color-text);word-break:break-all;line-height:1.375';
  const badgeBase = 'display:inline-flex;align-items:center;flex-shrink:0;border-radius:0.25rem;padding:0.125rem 0.375rem;font-size:0.75rem;font-weight:600;font-family:var(--sl-font-mono)';

  function position(pop, link) {
    const rect = link.getBoundingClientRect();
    const W = 420;
    let left = rect.left;
    let top = rect.bottom + 8;
    if (left + W > window.innerWidth - 12) left = window.innerWidth - W - 12;
    if (left < 8) left = 8;
    if (top + 200 > window.innerHeight) top = rect.top - 8;
    pop.style.left = `${left}px`;
    pop.style.top = `${top}px`;
  }

  function showSection(link, code) {
    clearTimeout(hideTimer);
    const sec = sections[code];
    if (!sec?.rules.length && !sec?.description) return;

    const pop = getPop();
    let html = '';

    if (sec.name) {
      html += `<div style="font-weight:600;font-size:0.78rem;margin-bottom:${sec.description || sec.rules.length ? '4px' : '0'};color:var(--sl-color-text-accent)">${code}: ${sec.name}</div>`;
    }
    if (sec.description) {
      html += `<p style="font-size:0.8rem;color:var(--sl-color-gray-2);margin:0 0 ${sec.rules.length ? '10px' : '0'} 0;line-height:1.45">${ruleToHtml(sec.description)}</p>`;
    }
    for (const r of sec.rules) {
      const req = r.requirement.toLowerCase();
      html += `
        <div style="border:1px solid var(--sl-color-gray-5);border-radius:0.5rem;padding:1rem;display:flex;flex-direction:column;gap:0.5rem;background:var(--sl-color-bg-sidebar);margin-bottom:6px">
          <div style="display:flex;align-items:flex-start;gap:0.5rem;flex-wrap:wrap">
            <span style="${codeStyle}">${r.code}</span>
            <span style="${badgeBase};background:var(--sl-pop-${req}-bg);color:var(--sl-pop-${req}-fg)">${r.requirement}</span>
          </div>
          <p style="font-size:0.875rem;color:var(--sl-color-gray-2);margin:0;line-height:1.5">${ruleToHtml(r.rule)}</p>
        </div>`;
    }

    pop.innerHTML = html;
    position(pop, link);
    pop.classList.add('visible');
  }

  function showTerm(link, termId) {
    clearTimeout(hideTimer);
    const term = terms[termId];
    if (!term) return;

    const pop = getPop();
    pop.innerHTML = `
      <div style="font-weight:600;font-size:0.85rem;margin-bottom:6px;color:var(--sl-color-text-accent)">${ruleToHtml(term.label)}</div>
      <p style="font-size:0.875rem;color:var(--sl-color-gray-2);margin:0;line-height:1.5">${ruleToHtml(term.definition)}</p>`;

    position(pop, link);
    pop.classList.add('visible');
  }

  function hide() {
    hideTimer = setTimeout(() => {
      document.getElementById('sl-section-popover')?.classList.remove('visible');
    }, 150);
  }

  // Event delegation — only inside the main content area, never in TOC/nav/sidebar
  document.addEventListener('mouseover', (e) => {
    const link = e.target?.closest?.('a[href*="#"]');
    if (!link) return;
    if (!link.closest('.sl-markdown-content')) return;

    const hash = link.getAttribute('href')?.split('#')[1];
    if (!hash) return;

    // Term link: hash matches a known term id directly (e.g. #slug, #uuid-hex)
    if (terms[hash]) { showTerm(link, hash); return; }

    // Section link: hash starts with digits (e.g. #321-definition-and-representation → G321)
    const code = hashToSectionCode(hash);
    if (!code) return;
    const sec = sections[code];
    if (!sec?.rules.length && !sec?.description) return;
    showSection(link, code);
  });

  document.addEventListener('mouseout', (e) => {
    const link = e.target?.closest?.('a[href*="#"]');
    if (!link) return;
    if (link.contains(e.relatedTarget)) return;
    const pop = document.getElementById('sl-section-popover');
    if (pop?.contains(e.relatedTarget)) { clearTimeout(hideTimer); return; }
    hide();
  });

  // Ensure popover element exists after each page load (View Transitions)
  document.addEventListener('astro:page-load', getPop);
  if (document.readyState !== 'loading') getPop();
</script>
