---
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

interface Props {
  sectionCode: string;
}

const { sectionCode } = Astro.props;

const dbPath = path.join(process.cwd(), 'src/crud.db');
const db = new DatabaseSync(dbPath);
const row = db.prepare('SELECT description FROM crud_sections WHERE id = ?').get(sectionCode) as {
  description: string | null;
} | undefined;
db.close();

function descToHtml(text: string): string {
  return text
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_, linkText, url) => {
      const external = url.startsWith('http');
      const attrs = external ? ' target="_blank" rel="noopener noreferrer"' : '';
      return `<a href="${url}"${attrs}>${linkText}</a>`;
    })
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\\\$/g, '$');
}

const html = row?.description ? descToHtml(row.description) : null;
---

{html && <p set:html={html} />}
